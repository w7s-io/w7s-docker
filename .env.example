W7S_DOCKER_PORT=8787
W7S_DOCKER_BASE_DOMAIN=apps.example.com
W7S_DOCKER_DEPLOY_TOKEN=change-me

# Set this when using the cloudflared Compose profile.
TUNNEL_TOKEN=

# Build/deploy metadata. The release script fills these for production images.
W7S_DOCKER_BRANCH=local
W7S_DOCKER_COMMIT_HASH=unknown
W7S_DOCKER_DEPLOYED_AT=unknown
