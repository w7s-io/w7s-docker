{
  "name": "w7s-docker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "w7s-docker": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "build:image": "bash scripts/build-image.sh",
    "deploy:example": "tsx scripts/deploy-example.ts",
    "test:smoke": "tsx test/smoke.ts"
  },
  "dependencies": {
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "yazl": "^3.3.1"
  }
}
